import { createContext, useContext, useState, ReactNode } from "react";

export interface CartItem {
  lang: string;
  flag: string;
  price: string;
  priceNum: number;
}

interface CartContextType {
  items: CartItem[];
  addItem: (item: CartItem) => void;
  removeItem: (lang: string) => void;
  clearCart: () => void;
  total: number;
  isOpen: boolean;
  setIsOpen: (open: boolean) => void;
}

const CartContext = createContext<CartContextType | undefined>(undefined);

export const CartProvider = ({ children }: { children: ReactNode }) => {
  const [items, setItems] = useState<CartItem[]>([]);
  const [isOpen, setIsOpen] = useState(false);

  const addItem = (item: CartItem) => {
    setItems((prev) => {
      if (prev.find((i) => i.lang === item.lang)) return prev;
      return [...prev, item];
    });
  };

  const removeItem = (lang: string) => {
    setItems((prev) => prev.filter((i) => i.lang !== lang));
  };

  const clearCart = () => setItems([]);

  const total = items.reduce((sum, i) => sum + i.priceNum, 0);

  return (
    <CartContext.Provider value={{ items, addItem, removeItem, clearCart, total, isOpen, setIsOpen }}>
      {children}
    </CartContext.Provider>
  );
};

export const useCart = () => {
  const ctx = useContext(CartContext);
  if (!ctx) throw new Error("useCart must be used within CartProvider");
  return ctx;
};
